{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BridgeEventEnvelope (npc)",
  "description": "Bridge envelope for the NPC service. Extend with npc-specific event schemas as the protocol is defined.",
  "type": "object",
  "required": ["event_type", "name", "payload"],
  "properties": {
    "event_type": { "type": "string", "enum": ["core", "plugin"] },
    "namespace":  { "type": ["string", "null"] },
    "name":       { "type": "string" },
    "payload":    { "type": "object" }
  }
}
