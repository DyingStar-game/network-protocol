{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "player.init",
  "description": "Sent by the game client to Horizon immediately after WebSocket connection to authenticate.",
  "type": "object",
  "required": ["namespace", "event", "data"],
  "properties": {
    "namespace": { "type": "string", "enum": ["player"] },
    "event":     { "type": "string", "enum": ["init"] },
    "data": {
      "type": "object",
      "required": ["token"],
      "properties": {
        "token": { "type": "string", "description": "Authentication token (JWT or opaque)" }
      }
    }
  }
}
