{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "player.move",
  "description": "Sent by the game client to update the player's movement direction and rotation.",
  "type": "object",
  "required": ["namespace", "event", "data"],
  "properties": {
    "namespace": { "type": "string", "enum": ["player"] },
    "event":     { "type": "string", "enum": ["move"] },
    "data": {
      "type": "object",
      "required": ["dir", "rot"],
      "properties": {
        "dir": { "$ref": "#/$defs/vec3" },
        "rot": { "$ref": "#/$defs/vec3" }
      }
    }
  },
  "$defs": {
    "vec3": {
      "type": "object",
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      }
    }
  }
}
