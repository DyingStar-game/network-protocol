{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "persistence response: items_chunk",
  "description": "Sent by persistence to Horizon with a batch of items. Multiple chunks may be sent before items_end.",
  "type": "object",
  "required": ["event_type", "name", "payload"],
  "properties": {
    "event_type": { "type": "string", "enum": ["core", "plugin"] },
    "namespace":  { "type": ["string", "null"] },
    "name":       { "type": "string", "enum": ["items_chunk"] },
    "payload": {
      "type": "array",
      "items": { "$ref": "#/$defs/item" }
    }
  },
  "$defs": {
    "vec3": {
      "type": "object",
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      }
    },
    "item": {
      "type": "object",
      "required": ["object_type", "uuid", "object_data"],
      "properties": {
        "object_type": { "type": "string" },
        "uuid":        { "type": "string" },
        "parent_id":   { "type": ["string", "null"] },
        "scenename":   { "type": ["string", "null"] },
        "position":    { "$ref": "#/$defs/vec3" },
        "rotation":    { "$ref": "#/$defs/vec3" },
        "object_data": { "type": "array" }
      }
    }
  }
}
