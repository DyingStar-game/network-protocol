{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "player.error",
  "description": "Sent by Horizon to report a protocol-level error to the client.",
  "type": "object",
  "required": ["namespace", "event", "data"],
  "properties": {
    "namespace": { "type": "string", "enum": ["player"] },
    "event":     { "type": "string", "enum": ["error"] },
    "data": {
      "type": "object",
      "required": ["player_id", "type_", "code", "message"],
      "properties": {
        "player_id": { "type": "string" },
        "type_":     { "type": "string" },
        "code":      { "type": "integer" },
        "message":   { "type": "string" }
      }
    }
  }
}
