{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "server.prop_event",
  "description": "Shared shape for add_prop, update_prop, initial_object, freeze_object — all carry object_type, object_uuid, object_data.",
  "type": "object",
  "required": ["namespace", "event", "data"],
  "properties": {
    "namespace": { "type": "string", "enum": ["server"] },
    "event": {
      "type": "string",
      "enum": ["add_prop", "update_prop", "initial_object", "freeze_object"]
    },
    "data": {
      "type": "object",
      "required": ["object_type", "object_uuid", "object_data"],
      "properties": {
        "object_type": {
          "type": "string",
          "description": "Object type identifier, e.g. planet, player, box50cm"
        },
        "object_uuid": { "type": "string" },
        "object_data": {
          "type": "object",
          "description": "Type-specific data; position and rotation are common fields.",
          "properties": {
            "position": { "$ref": "#/$defs/vec3" },
            "rotation": { "$ref": "#/$defs/vec3" }
          }
        }
      }
    }
  },
  "$defs": {
    "vec3": {
      "type": "object",
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      }
    }
  }
}
