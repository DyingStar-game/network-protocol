{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "server.freeze_object",
  "description": "Sent by Horizon to freeze (stop simulating) an object on the client.",
  "type": "object",
  "required": ["namespace", "event", "data"],
  "properties": {
    "namespace": { "type": "string", "enum": ["server"] },
    "event":     { "type": "string", "enum": ["freeze_object"] },
    "data": {
      "type": "object",
      "required": ["object_type", "object_uuid", "object_data"],
      "properties": {
        "object_type": { "type": "string" },
        "object_uuid": { "type": "string" },
        "object_data": {
          "type": "object",
          "properties": {
            "position": { "$ref": "#/$defs/vec3" },
            "rotation": { "$ref": "#/$defs/vec3" }
          }
        }
      }
    }
  },
  "$defs": {
    "vec3": {
      "type": "object",
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      }
    }
  }
}
