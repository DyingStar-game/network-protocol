{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "server.remove_player",
  "description": "Sent by Horizon to remove a player object from the client's world.",
  "type": "object",
  "required": ["namespace", "event", "data"],
  "properties": {
    "namespace": { "type": "string", "enum": ["server"] },
    "event":     { "type": "string", "enum": ["remove_player"] },
    "data": {
      "type": "object",
      "required": ["object_uuid"],
      "properties": {
        "object_uuid": { "type": "string" }
      }
    }
  }
}
