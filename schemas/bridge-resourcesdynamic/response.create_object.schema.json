{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "resourcesDynamic response: genericprops.create_object",
  "description": "Sent by resourcesDynamic to Horizon with the initial object list (positions + rotations over time) for a solar system.",
  "type": "object",
  "required": ["namespace", "event", "data"],
  "properties": {
    "namespace": { "type": "string", "enum": ["genericprops"] },
    "event":     { "type": "string", "enum": ["create_object"] },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["object_type", "object_uuid", "object_data"],
        "properties": {
          "object_type": { "type": "string" },
          "object_uuid": { "type": "string" },
          "object_data": {
            "type": "object",
            "required": ["scenename", "from_timestamp", "positions", "rotations"],
            "properties": {
              "name":           { "type": "string" },
              "scenename":      { "type": "string" },
              "parent_id":      { "type": "string" },
              "from_timestamp": { "type": "integer" },
              "positions": {
                "type": "array",
                "items": { "$ref": "#/$defs/vec3" }
              },
              "rotations": {
                "type": "array",
                "items": { "$ref": "#/$defs/vec3" }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "vec3": {
      "type": "object",
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      }
    }
  }
}
